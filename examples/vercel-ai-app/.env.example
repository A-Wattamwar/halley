# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# OTLP/HTTP endpoint for Halley's ingester.
# The OTEL SDK reads this standard env var directly.
# Appends /v1/traces automatically when set as the base URL.
# instrumentation.ts uses this as the full traces URL.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
