# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Halley ingester OTLP/HTTP endpoint.
# traceloop-sdk reads TRACELOOP_BASE_URL and appends /v1/traces automatically.
TRACELOOP_BASE_URL=http://localhost:4318

# Optional: override the model (default: gpt-4o-mini per D-43)
# MODEL_NAME=gpt-4o-mini

# Optional: enable prompt/completion content capture in spans (default: true in traceloop-sdk >= 0.28)
# TRACELOOP_TRACE_CONTENT=true
