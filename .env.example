# Halley local development configuration.
# Copy to .env and adjust. .env is gitignored.
#
# These are DEV-ONLY defaults. Never deploy a stack with these values.

# ---------- Ingester ----------
INGESTER_HTTP_ADDR=0.0.0.0:4318
INGESTER_GRPC_ADDR=0.0.0.0:4317
INGESTER_LOG_LEVEL=info
INGESTER_LOG_JSON=true

# ---------- ClickHouse ----------
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=halley
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=halley
POSTGRES_USER=halley
POSTGRES_PASSWORD=halley

# ---------- Redis ----------
# Host-side default (npm run dev, host scripts): use port 6380 — the Docker
# Redis maps host:6380 → container:6379, avoiding collision with any native
# Redis on localhost:6379 (same fix as Postgres 5433:5432).
# In-container services (dashboard, worker) override this to redis://redis:6379/0
# via docker-compose.yml environment: block so they use the in-network name.
REDIS_URL=redis://localhost:6380/0

# ---------- Dashboard ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Auth.js (Phase 4) ----------
# Generate a real secret with: openssl rand -hex 32
NEXTAUTH_SECRET=halley-dev-secret-change-in-prod
NEXTAUTH_URL=http://localhost:3000
# Postgres connection string for Auth.js adapter (same DB as ingester)
POSTGRES_URL=postgresql://halley:halley@localhost:5433/halley
# Set to false to bypass auth in local dev and smoke tests (D-15)
HALLEY_AUTH_REQUIRED=false
