# Halley local development configuration.
# Copy to .env and adjust. .env is gitignored.
#
# These are DEV-ONLY defaults. Never deploy a stack with these values.

# ---------- Ingester ----------
INGESTER_HTTP_ADDR=0.0.0.0:4318
INGESTER_GRPC_ADDR=0.0.0.0:4317
INGESTER_LOG_LEVEL=info
INGESTER_LOG_JSON=true

# ---------- ClickHouse ----------
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=halley
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=halley
POSTGRES_USER=halley
POSTGRES_PASSWORD=halley

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Dashboard ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Auth.js (Phase 4) ----------
# Generate a real secret with: openssl rand -hex 32
NEXTAUTH_SECRET=halley-dev-secret-change-in-prod
NEXTAUTH_URL=http://localhost:3000
# Postgres connection string for Auth.js adapter (same DB as ingester)
POSTGRES_URL=postgresql://halley:halley@localhost:5432/halley
# Set to false to bypass auth in local dev and smoke tests (D-15)
HALLEY_AUTH_REQUIRED=false
